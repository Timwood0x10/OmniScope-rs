# OmniScope-rs .gitignore

# Build artifacts
/target/
/build/
**/*.rs.bk
*.pdb

# Cargo (keep Cargo.lock for binary crate)
**/Cargo.lock

# IDE and Editor
.vscode/
.idea/
.fleet/
*.swp
*.swo
*~

# Tool directories
.joycode/
.claude/
.codeartsdoer/
.codegraph/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Test and Coverage
/coverage/
*.profraw
*.profdata
/tarpaulin-report.html
/cobertura.xml
*.lcov

# Profiling
flamegraph.svg
perf.data
perf.data.old

# Temporary and backup files
*.tmp
*.temp
*.log
*.bak
*.backup
*.orig
*.rej

# LLVM build artifacts (NOT source .ll corpus files)
*.bc
*.o
*.a
*.lib
*.obj
pass/build/
pass/compile_commands.json
tests/integration/

# Compressed archives
*.zip
*.tar.gz
*.tar.bz2
*.7z

# Dependency directories
node_modules/

# Python cache
__pycache__/
*.py[cod]
*$py.class
.Python

# Output/cache
/output/
/results/
*.json.bak
*.toml.bak
.cache/
*.cache

# Secrets (never commit)
.env
.env.*
*.pem
*.key
secrets/
credentials/

# Database files
*.db
*.sqlite
*.sqlite3

# Jupyter
.ipynb_checkpoints/

# aim (ML experiment tracking)
aim/